d{
  "name": "owox-harness-control",
  "dockerComposeFile": "compose.yml",
  "service": "control",
  "remoteUser": "root",
  "runServices": [
    "control"
  ],
  "features": {
    "ghcr.io/devcontainers/features/node:2.0.0": {
      "version": "lts",
      "nvmVersion": "0.40"
    }
  },
  "workspaceFolder": "/workspace/product",
  "postCreateCommand": "bash /workspace/product/.devcontainer/scripts/post-create.sh",
  "customizations": {
    "vscode": {
      "settings": {
        "terminal.integrated.cwd": "/workspace/product/control",
        "rust-analyzer.linkedProjects": [
          "/workspace/product/target/Cargo.toml"
        ]
      },
      "extensions": [
        "rust-lang.rust-analyzer",
        "vadimcn.vscode-lldb"
      ]
    }
  }
}
